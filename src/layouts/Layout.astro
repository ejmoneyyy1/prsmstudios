---
import { ArrowRight } from 'lucide-astro';
import BaseHead from '../components/BaseHead.astro';
import PrismBackground from '../components/PrismBackground.astro';
import Grain from '../components/Grain.astro';
import PrsmLogoMark from '../components/PrsmLogoMark.astro';
import '../styles/global.css';
import { PRESENCE_AUDIT_HREF, SITE_TITLE, SITE_DESCRIPTION, SITE_URL } from '../consts';

export interface Props {
  /** Full `<title>`; defaults to SITE_TITLE */
  title?: string;
  /** Meta / OG description; defaults to SITE_DESCRIPTION */
  description?: string;
  /** `website` for homepage & services; `article` for case studies */
  ogType?: 'website' | 'article';
}

const {
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  ogType = 'website',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, SITE_URL);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={title}
      description={description}
      ogType={ogType}
      canonicalURL={canonicalURL}
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter+Tight:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900&family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (() => {
        const ua = navigator.userAgent;
        const isSafari =
          /Safari/i.test(ua) && !/Chrome|Chromium|CriOS|Edg|OPR|Firefox|FxiOS/i.test(ua);
        if (!isSafari) return;
        document.documentElement.setAttribute('data-browser', 'safari');
      })();
    </script>
  </head>
  <body>
    <PrismBackground />
    <Grain />
    <header
      id="site-nav"
      class="site-nav fixed top-0 inset-x-0 z-[10050] pointer-events-none border-b border-black/[0.08] bg-[rgba(250,250,250,0.88)] shadow-[0_8px_32px_-8px_rgba(0,0,0,0.08)] backdrop-saturate-150 supports-[backdrop-filter]:bg-[rgba(250,250,250,0.78)]"
    >
      <!-- Mobile: no overlap — tap targets ≥44px, CTA full-width row -->
      <div
        class="site-nav-mobile mx-auto w-full max-w-6xl px-4 pt-[max(0.5rem,env(safe-area-inset-top))] pb-3 pointer-events-auto md:hidden flex flex-col gap-3"
      >
        <div class="flex items-center justify-between gap-2">
          <a
            href="/"
            class="site-nav-tap text-[#0D0D0D]/75 text-xs tracking-[0.18em] uppercase hover:text-[#0D0D0D] transition-colors -ml-1 px-2 py-2.5"
          >
            About
          </a>
          <a
            href="/"
            class="site-nav-tap flex items-center gap-2 text-[#0D0D0D] px-2 py-1.5"
            aria-label="PRSM Studio — Home"
          >
            <PrsmLogoMark class="h-7 w-7 shrink-0" idPrefix="nav-m" />
            <span class="whitespace-nowrap font-black tracking-[0.16em] uppercase text-[11px]">PRSM</span>
          </a>
          <a
            href="/brand-reframing"
            class="site-nav-tap text-[#0D0D0D]/75 text-xs tracking-[0.18em] uppercase hover:text-[#0D0D0D] transition-colors -mr-1 px-2 py-2.5"
          >
            Work
          </a>
        </div>
        <a
          href={PRESENCE_AUDIT_HREF}
          data-magnetic
          class="presence-audit-btn inline-flex min-h-[44px] w-full items-center justify-center gap-2 rounded-full border border-black/20 bg-white/90 backdrop-blur-xl px-4 py-2.5 text-sm font-semibold text-black shadow-[0_0_20px_rgba(0,0,0,0.1)] transition-all active:scale-[0.99] hover:bg-white"
        >
          <span class="truncate">Request audit</span>
          <ArrowRight class="h-4 w-4 shrink-0" aria-hidden="true" />
        </a>
      </div>

      <!-- Desktop / tablet: original centered layout -->
      <div class="mx-auto hidden h-20 max-w-6xl px-6 md:block md:px-12 relative">
        <a
          href="/"
          class="pointer-events-auto absolute left-0 top-7 text-[#0D0D0D]/75 text-xs tracking-[0.22em] uppercase hover:text-[#0D0D0D] transition-colors"
        >
          About
        </a>
        <a
          href="/brand-reframing"
          class="pointer-events-auto absolute right-0 top-7 text-[#0D0D0D]/75 text-xs tracking-[0.22em] uppercase hover:text-[#0D0D0D] transition-colors"
        >
          Work
        </a>

        <div class="pointer-events-none absolute left-1/2 top-3 flex -translate-x-1/2 items-center gap-3">
          <a
            href="/"
            class="pointer-events-auto flex items-center gap-2.5 text-[#0D0D0D]"
            aria-label="PrsmStudios — Home"
          >
            <PrsmLogoMark class="h-9 w-9 shrink-0" idPrefix="nav-d" />
            <div class="flex flex-col items-start leading-tight">
              <span
                class="bg-gradient-to-r from-cyan-500 via-fuchsia-500 to-amber-400 bg-clip-text text-sm font-bold tracking-tight text-transparent md:text-base"
              >
                PrsmStudios
              </span>
              <span
                class="text-[8px] font-semibold uppercase tracking-[0.28em] text-[#0D0D0D]/45 md:text-[9px]"
              >
                Digital consulting
              </span>
            </div>
          </a>
          <a
            href={PRESENCE_AUDIT_HREF}
            data-magnetic
            class="presence-audit-btn pointer-events-auto inline-flex items-center gap-2 rounded-full border border-black/20 bg-white/85 backdrop-blur-xl px-5 py-2 text-black font-semibold shadow-[0_0_20px_rgba(0,0,0,0.12)] transition-all hover:bg-white"
          >
            <span>Request a Presence Audit</span>
            <ArrowRight class="h-4 w-4" aria-hidden="true" />
          </a>
        </div>
      </div>
    </header>

    <!-- Lenis moves only the content layer; header + Prism remain fixed -->
    <!-- Use dvh to avoid mobile iOS address-bar viewport glitches -->
    <div
      id="lenis-wrapper"
      class="relative z-[10000] h-screen overflow-hidden"
      data-smooth-wrapper
    >
      <div id="lenis-content">
        <div id="smooth-content">
          <slot />
        </div>
      </div>
    </div>

    <!-- Import client script (Astro processes/bundles TS). -->
    <script>
      import '@scripts/site.ts';
    </script>
  </body>
</html>
