---
import Layout from '../layouts/Layout.astro';
import CaseDetail from '../components/CaseDetail.astro';
import { getCaseById } from '../data/cases';
import { SITE_NAME } from '../consts';

const caseData = getCaseById('brand-reframing');

if (!caseData) {
  throw new Error('Missing case data for brand-reframing');
}
---

<Layout title={`${caseData.title} | ${SITE_NAME}`} description={caseData.summary} ogType="article">
  <CaseDetail case={caseData}>
    <section class="relative z-20 py-10">
      <h2 data-reveal="chars" class="text-2xl md:text-3xl font-semibold tracking-tight text-[#0D0D0D]">
        Approach
      </h2>
      <p class="mt-4 text-[#0D0D0D]/60 leading-relaxed max-w-3xl">
        We turn brand ambiguity into a clear, high-trust narrative: positioning first, then identity systems that
        feel inevitable across every surface.
      </p>

      <div class="mt-10 grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="rounded-2xl border border-black/10 bg-black/5 backdrop-blur-md p-6 glass-surface">
          <div class="text-xs tracking-[0.35em] text-[#0D0D0D]/40 uppercase font-semibold">Deliverables</div>
          <ul class="mt-4 space-y-2 text-[#0D0D0D]/60 leading-relaxed">
            <li>Messaging + narrative framework</li>
            <li>Visual identity system</li>
            <li>Premium component + layout kit</li>
          </ul>
        </div>

        <div class="rounded-2xl border border-black/10 bg-black/5 backdrop-blur-md p-6 glass-surface">
          <div class="text-xs tracking-[0.35em] text-[#0D0D0D]/40 uppercase font-semibold">Outcomes</div>
          <ul class="mt-4 space-y-2 text-[#0D0D0D]/60 leading-relaxed">
            <li>Clear value, faster conversion</li>
            <li>Higher credibility in motion</li>
            <li>Consistency across touchpoints</li>
          </ul>
        </div>

        <div class="rounded-2xl border border-black/10 bg-black/5 backdrop-blur-md p-6 glass-surface">
          <div class="text-xs tracking-[0.35em] text-[#0D0D0D]/40 uppercase font-semibold">Why It Works</div>
          <ul class="mt-4 space-y-2 text-[#0D0D0D]/60 leading-relaxed">
            <li>Restraint makes the message louder</li>
            <li>Systems beat one-off redesigns</li>
            <li>Performance protects perception</li>
          </ul>
        </div>
      </div>
    </section>
  </CaseDetail>
</Layout>

