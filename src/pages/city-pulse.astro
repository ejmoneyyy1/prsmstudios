---
import Layout from '../layouts/Layout.astro';
import CaseDetail from '../components/CaseDetail.astro';
import CityPulse from '../components/CityPulse.astro';
import { getCaseById } from '../data/cases';
import { SITE_NAME } from '../consts';

const caseData = getCaseById('city-pulse');

if (!caseData) {
  throw new Error('Missing case data for city-pulse');
}
---

<Layout title={`${caseData.title} | ${SITE_NAME}`} description={caseData.summary} ogType="article">
  <CaseDetail case={caseData}>
    <CityPulse />
  </CaseDetail>
 </Layout>

