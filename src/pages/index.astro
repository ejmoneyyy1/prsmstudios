---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import FeaturedProject from '../components/FeaturedProject.astro';
import CityPulseShowcase from '../components/CityPulseShowcase.astro';
import CoreServices from '../components/CoreServices.astro';
import CasesList from '../components/CasesList.astro';
import SelectedWorks from '../components/SelectedWorks.astro';
import { CONTACT_EMAIL, PRESENCE_AUDIT_HREF } from '../consts';

const brandName = 'PRSM STUDIO';
const missionLine = 'Building and Rebranding High-Grade, Sustainable, and Scalable Solutions.';
const missionCopy =
  'A venture studio: we ship products and reframe brands with editorial craft—no résumé theater, only outcomes.';
---

<Layout title={`${brandName} — Venture Studio`}>
  <main class="relative z-10">
    <Hero />
    <FeaturedProject />
    <CityPulseShowcase />
    <CoreServices />
    <CasesList />
    <SelectedWorks />

    <footer class="relative py-60">
      <div class="mx-auto w-full max-w-6xl px-6 md:px-12">
        <div class="grid gap-10 md:grid-cols-2 items-start">
          <div>
            <div class="text-[#0D0D0D]/70 text-xs font-semibold tracking-widest uppercase">
              Venture studio
            </div>
            <h2 class="mt-3 text-2xl md:text-3xl font-semibold tracking-tight">
              {missionLine}
            </h2>
            <p class="mt-4 text-[#0D0D0D]/60 leading-relaxed">{missionCopy}</p>
          </div>

          <div
            class="rounded-2xl border border-black/10 bg-black/5 backdrop-blur-md p-7 glass-surface"
          >
            <a
              href={PRESENCE_AUDIT_HREF}
              class="presence-audit-btn mt-6 inline-flex items-center gap-2 rounded-full border border-black/20 bg-transparent px-5 py-2.5 backdrop-blur-md hover:border-black/40 hover:bg-black/5 transition-colors"
            >
              <span class="text-sm font-medium">Request a Presence Audit</span>
            </a>
          </div>
        </div>

        <div class="mt-12 pt-6 border-t border-black/10">
          <div class="text-[10px] tracking-[0.4em] uppercase text-[#0D0D0D]/40">____</div>

          <div class="mt-6">
            <div class="overflow-hidden">
              <div
                data-reveal="chars"
                class="text-2xl md:text-3xl font-semibold tracking-tight text-[#0D0D0D]"
              >
                Get in touch
              </div>
            </div>

            <div class="mt-4 flex flex-wrap items-center gap-x-6 gap-y-2">
              <a
                href={`mailto:${CONTACT_EMAIL}`}
                class="text-xs tracking-[0.25em] uppercase text-[#0D0D0D]/40 hover:text-[#0D0D0D] transition-colors"
              >
                Mail
              </a>
              <a
                href="https://www.linkedin.com/in/earl-alobuia-995318220/"
                target="_blank"
                rel="noreferrer"
                class="text-xs tracking-[0.25em] uppercase text-[#0D0D0D]/40 hover:text-[#0D0D0D] transition-colors"
              >
                Linkedin
              </a>
              <a
                href="https://www.instagram.com/ej.moneyyy/"
                target="_blank"
                rel="noreferrer"
                class="text-xs tracking-[0.25em] uppercase text-[#0D0D0D]/40 hover:text-[#0D0D0D] transition-colors"
              >
                Instagram
              </a>
            </div>
          </div>

          <div class="mt-10 text-sm text-[#0D0D0D]/60 flex flex-col md:flex-row gap-3 justify-between">
            <div>© {new Date().getFullYear()} {brandName}. All rights reserved.</div>
            <div class="flex items-center gap-3">
              <a
                class="hover:text-black transition-colors"
                href="/brand-reframing"
              >
                Brand Reframing
              </a>
              <span class="text-black/20">·</span>
              <a
                class="hover:text-black transition-colors"
                href="/city-pulse"
              >
                City Pulse
              </a>
            </div>
          </div>
        </div>
      </div>
    </footer>
  </main>
</Layout>

