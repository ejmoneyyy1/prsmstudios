---
/**
 * Google Play mark — path from Simple Icons (MIT), viewBox 0 0 24 24.
 */
interface Props {
  class?: string;
  /** Unique when multiple colorful icons exist on the page */
  gradientId?: string;
  colorful?: boolean;
}
const { class: className = 'h-8 w-8 shrink-0', gradientId = 'gp-fill', colorful = false } = Astro.props;
const gid = colorful ? gradientId : '';
const fillAttr = colorful && gid ? `url(#${gid})` : 'currentColor';
---

<svg
  class={className}
  viewBox="0 0 24 24"
  aria-hidden="true"
  xmlns="http://www.w3.org/2000/svg"
>
  {
    colorful && gid ? (
      <defs>
        <linearGradient id={gid} x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stop-color="#00D9FF" />
          <stop offset="35%" stop-color="#00F076" />
          <stop offset="70%" stop-color="#FFBC00" />
          <stop offset="100%" stop-color="#FF3D00" />
        </linearGradient>
      </defs>
    ) : null
  }
  <path fill={fillAttr} d="M22.018 13.298l-3.919 2.218-3.515-3.493 3.543-3.521 3.891 2.202a1.49 1.49 0 0 1 0 2.594zM1.337.924a1.486 1.486 0 0 0-.112.568v21.017c0 .217.045.419.124.6l11.155-11.087L1.337.924zm12.207 10.065l3.258-3.238L3.45.195a1.466 1.466 0 0 0-.946-.179l11.04 10.973zm0 2.067l-11 10.933c.298.036.612-.016.906-.183l13.324-7.54-3.23-3.21z" />
</svg>
