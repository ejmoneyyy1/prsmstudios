---
/**
 * Agency grain: organic film texture @ 3% opacity (pairs with global.css `.grain-agency__svg rect`).
 */
---

<div class="grain-agency grain-overlay" aria-hidden="true">
  <svg class="grain-agency__svg" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <filter id="grain-fractal-noise" color-interpolation-filters="sRGB" x="-20%" y="-20%" width="140%" height="140%">
        <feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch" result="noise" />
        <feColorMatrix type="saturate" values="0" in="noise" result="mono" />
      </filter>
    </defs>
    <rect width="100%" height="100%" filter="url(#grain-fractal-noise)" opacity="0.03" />
  </svg>
</div>
