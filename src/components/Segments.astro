---
import { PRESENCE_AUDIT_HREF } from '../consts';

const comparisonRows = [
  {
    label: 'Speed',
    generic: 'Multi-second loads & script bloat',
    prsm: 'Sub-second load',
  },
  {
    label: 'Ownership',
    generic: 'Rented stack, vendor lock-in',
    prsm: '100% Proprietary',
  },
  {
    label: 'Brand Unique-ness',
    generic: 'Cookie-cutter themes',
    prsm: 'Cinematic/Custom',
  },
  {
    label: 'Creative Control',
    generic: 'Platform Restrictions / Pre-set Layouts',
    prsm: 'Total Sovereignty. Built to your exact vision.',
  },
  {
    label: 'Scalability',
    generic: 'Plan ceilings & plugin debt',
    prsm: 'Infinite',
  },
];
---

<section
  id="target-segments"
  class="relative z-10 border-y border-black/10 bg-[#F4F4F5]/90 backdrop-blur-[10px]"
  aria-labelledby="target-segments-heading"
>
  <div class="mx-auto w-full max-w-6xl px-6 md:px-12">
    <p class="text-xs font-semibold uppercase tracking-[0.28em] text-zinc-500">Target segments</p>
    <h2
      id="target-segments-heading"
      class="mt-3 max-w-2xl text-2xl font-semibold tracking-tight text-zinc-950 md:text-3xl"
    >
      Ghost town or template trap — we engineer the exit.
    </h2>

    <!-- Two high-contrast cards -->
    <div class="mt-14 grid grid-cols-1 gap-6 lg:grid-cols-2 lg:gap-8">
      <article
        class="flex min-h-[280px] flex-col justify-between rounded-2xl border border-white/10 bg-zinc-950 px-8 py-10 text-white shadow-[0_32px_80px_-24px_rgba(0,0,0,0.45)] md:px-10 md:py-12"
      >
        <div>
          <p class="font-mono text-[10px] font-semibold uppercase tracking-[0.35em] text-zinc-400">
            The Invisible
          </p>
          <h3 class="mt-4 text-2xl font-bold leading-tight tracking-tight text-white md:text-3xl">
            From Ghost Town to Global Signal.
          </h3>
          <p class="mt-5 text-sm leading-relaxed text-zinc-300 md:text-base">
            A business without a digital presence is a business in decline. We architect your first and
            final digital headquarters—engineered for authority from Day 0.
          </p>
        </div>
        <p class="mt-8 font-mono text-[10px] uppercase tracking-[0.25em] text-zinc-500">
          For businesses with no site
        </p>
      </article>

      <article
        class="segments-signal-card segments-signal-card--light flex min-h-[280px] flex-col justify-between rounded-2xl border-2 border-zinc-950/90 bg-white/82 px-8 py-10 shadow-[0_24px_70px_-28px_rgba(0,0,0,0.12)] backdrop-blur-[10px] [-webkit-backdrop-filter:blur(10px)] md:px-10 md:py-12"
      >
        <div>
          <p class="font-mono text-[10px] font-semibold uppercase tracking-[0.35em] text-zinc-500">
            The Re-engineered
          </p>
          <h3 class="mt-4 text-2xl font-bold leading-tight tracking-tight text-zinc-950 md:text-3xl">
            Break the Template Trap.
          </h3>
          <p class="mt-5 text-sm leading-relaxed text-zinc-600 md:text-base">
            Plug-and-play platforms are built for the masses. We build proprietary, high-performance
            engines that outperform generic templates in speed, SEO, and conversion.
          </p>
        </div>
        <p class="mt-8 font-mono text-[10px] uppercase tracking-[0.25em] text-zinc-400">
          For Shopify & template users
        </p>
      </article>
    </div>

    <!-- Comparison -->
    <div class="mt-16 md:mt-20">
      <h3 class="text-center text-xs font-semibold uppercase tracking-[0.28em] text-zinc-500">
        Why us
      </h3>
      <p class="mx-auto mt-2 max-w-lg text-center text-sm text-zinc-600">
        Generic templates vs. PRSM engineering — same surface, different physics.
      </p>

      <div class="mt-10 overflow-x-auto rounded-xl border border-zinc-200 bg-white shadow-sm">
        <table class="w-full min-w-[520px] border-collapse text-left text-sm">
          <caption class="sr-only">
            Comparison of generic templates versus PRSM engineering across speed, ownership, brand
            uniqueness, creative control, and scalability
          </caption>
          <thead>
            <tr class="border-b border-zinc-200 bg-zinc-50/80">
              <th scope="col" class="px-5 py-4 font-mono text-[10px] font-semibold uppercase tracking-[0.2em] text-zinc-500 md:px-6">
                Dimension
              </th>
              <th scope="col" class="px-5 py-4 font-mono text-[10px] font-semibold uppercase tracking-[0.2em] text-zinc-500 md:px-6">
                Generic templates
              </th>
              <th
                scope="col"
                class="border-l border-zinc-200 bg-zinc-950 px-5 py-4 font-mono text-[10px] font-semibold uppercase tracking-[0.2em] text-zinc-300 md:px-6"
              >
                PRSM Engineering
              </th>
            </tr>
          </thead>
          <tbody>
            {
              comparisonRows.map((row) => (
                <tr class="border-b border-zinc-100 last:border-0">
                  <th
                    scope="row"
                    class="whitespace-nowrap px-5 py-4 font-semibold text-zinc-900 md:px-6"
                  >
                    {row.label}
                  </th>
                  <td class="px-5 py-4 text-zinc-500 md:px-6">{row.generic}</td>
                  <td
                    class="border-l border-zinc-800 bg-zinc-950 px-5 py-4 font-medium text-zinc-100 md:px-6"
                  >
                    {row.prsm}
                  </td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </div>

    <!-- CTA -->
    <div class="mt-14 flex flex-col items-center text-center md:mt-16">
      <a
        href={PRESENCE_AUDIT_HREF}
        data-magnetic
        class="presence-audit-btn inline-flex min-h-[48px] items-center justify-center rounded-full border border-zinc-900 bg-zinc-950 px-8 py-3 text-sm font-semibold uppercase tracking-[0.12em] text-white shadow-lg transition-colors hover:bg-zinc-900"
      >
        Request a Presence Audit
      </a>
      <p class="mt-4 max-w-md text-sm leading-relaxed text-zinc-600">
        Whether you&apos;re starting from zero or escaping a template, we define the roadmap.
      </p>
    </div>
  </div>
</section>
