---
import { Sparkles } from 'lucide-astro';
import PrismPreview from './PrismPreview.astro';

const subhead =
  'Building and Rebranding High-Grade, Sustainable, and Scalable Solutions.';
---

<section
  class="hero-display-section hero-perspective-hub relative z-10 overflow-x-hidden pt-20 pb-14 will-change-transform safari-depth-lock sm:pt-24 md:pb-24 md:pt-28"
  data-hero-section
>
  <!-- Colorful panes — pushed into -Z space (Safari cannot flatten with headline) -->
  <div
    class="hero-prsm-fx-layer hero-prsm-fx-pane-depth absolute inset-0 z-[1] pointer-events-none"
    aria-hidden="true"
  >
    <div data-prsm-beam-in class="absolute left-0 top-1/2 h-px bg-black/80 w-0"></div>
    <div data-prsm-fan="c" class="absolute left-1/2 top-1/2 h-px w-0 bg-cyan-300/50 blur-[1px]"></div>
    <div data-prsm-fan="m" class="absolute left-1/2 top-1/2 h-px w-0 bg-fuchsia-300/45 blur-[1px]"></div>
    <div data-prsm-fan="g" class="absolute left-1/2 top-1/2 h-px w-0 bg-yellow-200/45 blur-[1px]"></div>
    <div data-prsm-fan="w" class="absolute left-1/2 top-1/2 h-px w-0 bg-black/20 blur-[1px]"></div>
  </div>

  <div class="hero-newspaper-shell relative z-[2] mx-auto w-full px-4 sm:px-6 md:px-10 lg:px-12">
    <div class="relative mx-auto w-full max-w-[100rem]">
      <!-- 12-col newspaper grid: full width + min-height for Safari vw/clamp in nested grids -->
      <div
        class="hero-newspaper-grid grid min-h-[100vh] w-full grid-cols-1 gap-12 lg:min-h-[100vh] lg:grid-cols-12 lg:gap-6 xl:gap-8"
      >
        <div class="hero-newspaper-stack min-w-0 lg:col-span-8 lg:col-start-1">
          <header class="hero-newspaper-masthead" aria-label="Venture studio headline">
            <p class="hero-newspaper-label">Venture Studio</p>

            <h1
              data-reveal="lines"
              data-reveal-hero
              class="hero-headline hero-newspaper-headline"
            >
              The Digital Landscape Is a Ghost Town. We Build the Signal.
            </h1>

            <p data-hero-mission class="hero-newspaper-mission">
              {subhead}
            </p>

            <div class="hero-newspaper-pill">
              <div class="hero-newspaper-pill__inner">
                <Sparkles class="hero-newspaper-pill__icon shrink-0 text-black/70" strokeWidth={1.5} aria-hidden="true" />
                <span class="hero-newspaper-pill__text">
                  PRSM CONSULTING: BRAND REFRAMING | EXPERIENCE ENGINEERING
                </span>
              </div>
            </div>
          </header>
        </div>

        <div
          class="hero-vault-column min-w-0 w-full lg:col-span-4 lg:col-start-9 lg:self-center"
        >
          <div class="hero-vault-scale mx-auto w-full max-w-lg lg:max-w-none">
            <PrismPreview heroBillboard />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
