---
import { selectedWorks } from '../data/selectedWorks';
---

<section id="showreel" class="relative z-20 py-14">
  <div class="mx-auto w-full max-w-6xl px-6 md:px-12">
    <div class="flex items-start justify-between gap-10">
      <div class="max-w-xl">
        <div class="overflow-hidden">
          <div
            data-reveal="chars"
            class="text-xs tracking-[0.35em] text-[#0D0D0D]/40 uppercase"
          >
            Showreel
          </div>
        </div>
      </div>
    </div>

    <div class="mt-10 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-x-10 gap-y-10">
      {selectedWorks.map((w) => (
        <a
          href={w.href}
          class="group block pt-6 border-t border-black/10"
        >
          <div class="text-2xl md:text-3xl font-semibold tracking-tight text-[#0D0D0D]">
            {w.title}
          </div>
          {w.meta ? (
            <div class="mt-4 text-xs tracking-[0.25em] text-[#0D0D0D]/30 uppercase">
              {w.meta}
            </div>
          ) : null}
          <div class="mt-5 h-px w-full bg-black/10 group-hover:bg-black/20 transition-colors" />
          <div
            class="mt-4 text-xs tracking-[0.3em] text-[#0D0D0D]/30 uppercase transition-all group-hover:text-[#0D0D0D] group-hover:translate-x-1"
          >
            View
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

