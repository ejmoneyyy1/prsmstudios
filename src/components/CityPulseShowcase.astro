---
import {
  CITY_PULSE_APP_STORE_URL,
  CITY_PULSE_PLAY_STORE_URL,
  CITY_PULSE_UI_SCREENSHOT,
  CITY_PULSE_UI_VIDEO_URL,
} from '../consts';
import StoreAppleIcon from './icons/StoreAppleIcon.astro';
import StoreGooglePlayIcon from './icons/StoreGooglePlayIcon.astro';

const hasVideo = Boolean(CITY_PULSE_UI_VIDEO_URL);
const appHref = CITY_PULSE_APP_STORE_URL || null;
const playHref = CITY_PULSE_PLAY_STORE_URL || null;

const features = [
  {
    n: '01',
    title: 'REAL-TIME DISCOVERY',
    body: 'Low-latency data streams for urban navigation.',
  },
  {
    n: '02',
    title: 'CINEMATIC INTERFACE',
    body: 'Aerospace-grade UI precision.',
  },
  {
    n: '03',
    title: 'GEOSPATIAL INTELLIGENCE',
    body: 'Proprietary mapping engine.',
  },
];
---

<section
  id="city-pulse"
  data-city-pulse-showcase
  class="relative z-10 py-20 md:py-28 overflow-hidden"
  aria-labelledby="city-pulse-showcase-title"
>
  <div class="mx-auto w-full max-w-6xl px-6 md:px-12">
    <p class="text-xs uppercase tracking-[0.22em] text-black/45">Product reveal</p>
    <h2
      id="city-pulse-showcase-title"
      class="mt-3 text-2xl md:text-3xl font-semibold tracking-tight text-[#0D0D0D]"
    >
      City Pulse — in your hand
    </h2>
    <p class="mt-2 text-sm text-[#0D0D0D]/55 max-w-2xl">
      A live look at the interface: discovery, motion, and map intelligence in one surface.
    </p>

    <div class="mt-14 grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
      <!-- Device mockup -->
      <div class="lg:col-span-5 flex justify-center lg:justify-start">
        <div
          data-showcase-device
          class="relative w-[min(100%,280px)] shrink-0 [will-change:transform,opacity]"
        >
          <!-- Minimal iPhone frame: SVG silhouette + CSS -->
          <div
            class="relative rounded-[2.75rem] border border-black/12 bg-gradient-to-b from-zinc-800 to-zinc-950 p-[11px] shadow-[0_24px_60px_rgba(0,0,0,0.18),inset_0_1px_0_rgba(255,255,255,0.08)]"
          >
            <!-- Side buttons (decorative) -->
            <div
              class="absolute -left-[2px] top-[18%] h-10 w-[3px] rounded-l-sm bg-zinc-700/90"
              aria-hidden="true"
            ></div>
            <div
              class="absolute -left-[2px] top-[26%] h-16 w-[3px] rounded-l-sm bg-zinc-700/90"
              aria-hidden="true"
            ></div>
            <div
              class="absolute -right-[2px] top-[22%] h-20 w-[3px] rounded-r-sm bg-zinc-700/90"
              aria-hidden="true"
            ></div>

            <div
              class="relative overflow-hidden rounded-[2.15rem] bg-black aspect-[9/19.5] ring-1 ring-white/10"
            >
              <!-- Dynamic island / notch -->
              <div
                class="absolute left-1/2 top-2 z-20 h-[28px] w-[95px] -translate-x-1/2 rounded-full bg-black shadow-inner"
                aria-hidden="true"
              ></div>

              <!-- Screen content -->
              <div class="absolute inset-0 z-10">
                {hasVideo ? (
                  <video
                    class="h-full w-full object-cover"
                    src={CITY_PULSE_UI_VIDEO_URL}
                    poster={CITY_PULSE_UI_SCREENSHOT}
                    autoplay
                    muted
                    loop
                    playsinline
                    preload="metadata"
                  />
                ) : (
                  <img
                    src={CITY_PULSE_UI_SCREENSHOT}
                    alt="City Pulse app interface"
                    class="h-full w-full object-cover"
                    loading="lazy"
                    decoding="async"
                  />
                )}
              </div>

              <!-- Glass screen sheen -->
              <div
                class="pointer-events-none absolute inset-0 z-[15] bg-gradient-to-br from-white/[0.07] via-transparent to-transparent"
                aria-hidden="true"
              ></div>
            </div>
          </div>

          <!-- Subtle ground reflection -->
          <div
            class="pointer-events-none absolute -bottom-8 left-1/2 h-8 w-[70%] -translate-x-1/2 rounded-[100%] bg-black/[0.12] blur-xl"
            aria-hidden="true"
          ></div>
        </div>
      </div>

      <!-- Triad + stores -->
      <div class="lg:col-span-7 space-y-10">
        <ul class="space-y-8">
          {features.map((f) => (
            <li
              data-showcase-triad-item
              class="group border-b border-black/10 pb-8 last:border-0 last:pb-0 [will-change:transform,opacity]"
            >
              <div class="flex gap-5">
                <span class="text-xs font-semibold tracking-[0.35em] text-[#0D0D0D]/35 tabular-nums">
                  {f.n}
                </span>
                <div>
                  <h3 class="text-sm font-semibold tracking-[0.12em] text-[#0D0D0D]">{f.title}</h3>
                  <p class="mt-2 text-[#1A1A1A]/70 leading-relaxed max-w-xl">{f.body}</p>
                </div>
              </div>
            </li>
          ))}
        </ul>

        <div
          data-showcase-stores
          class="flex flex-wrap gap-4 pt-2 [will-change:transform,opacity]"
        >
          {appHref ? (
            <a
              href={appHref}
              target="_blank"
              rel="noreferrer"
              class="store-badge-glass inline-flex items-center gap-3 rounded-xl px-4 py-2.5 transition-transform hover:scale-[1.02] active:scale-[0.99]"
            >
              <StoreAppleIcon class="h-8 w-8 shrink-0 text-[#0D0D0D]" />
              <span class="text-left leading-tight">
                <span class="block text-[10px] text-[#1A1A1A]/70">Download on the</span>
                <span class="block text-base font-semibold tracking-tight text-[#0D0D0D]">App Store</span>
              </span>
            </a>
          ) : (
            <span
              class="store-badge-glass inline-flex items-center gap-3 rounded-xl px-4 py-2.5 opacity-70 cursor-not-allowed"
              title="App Store link coming soon"
            >
              <StoreAppleIcon class="h-8 w-8 shrink-0 text-[#0D0D0D]/80" />
              <span class="text-left leading-tight">
                <span class="block text-[10px] text-[#1A1A1A]/70">Download on the</span>
                <span class="block text-base font-semibold tracking-tight text-[#0D0D0D]">App Store</span>
              </span>
            </span>
          )}

          {playHref ? (
            <a
              href={playHref}
              target="_blank"
              rel="noreferrer"
              class="store-badge-glass inline-flex items-center gap-3 rounded-xl px-4 py-2.5 transition-transform hover:scale-[1.02] active:scale-[0.99]"
            >
              <StoreGooglePlayIcon class="h-8 w-8 shrink-0" colorful gradientId="gp-cp-active" />
              <span class="text-left leading-tight">
                <span class="block text-[10px] text-[#1A1A1A]/70">GET IT ON</span>
                <span class="block text-base font-semibold tracking-tight text-[#0D0D0D]">Google Play</span>
              </span>
            </a>
          ) : (
            <span
              class="store-badge-glass inline-flex items-center gap-3 rounded-xl px-4 py-2.5 opacity-70 cursor-not-allowed"
              title="Google Play link coming soon"
            >
              <StoreGooglePlayIcon class="h-8 w-8 shrink-0 opacity-90" colorful gradientId="gp-cp-soon" />
              <span class="text-left leading-tight">
                <span class="block text-[10px] text-[#1A1A1A]/70">GET IT ON</span>
                <span class="block text-base font-semibold tracking-tight text-[#0D0D0D]">Google Play</span>
              </span>
            </span>
          )}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .store-badge-glass {
    border: 1px solid rgba(0, 0, 0, 0.1);
    background: rgba(255, 255, 255, 0.45);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.6) inset, 0 8px 24px rgba(0, 0, 0, 0.06);
  }
</style>
