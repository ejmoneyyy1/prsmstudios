---
/**
 * Single home section: Venture pipeline + City Pulse product (merged former FeaturedProject + showcase).
 */
import {
  CITY_PULSE_APP_STORE_URL,
  CITY_PULSE_PLAY_STORE_URL,
  CITY_PULSE_UI_SCREENSHOT,
  CITY_PULSE_UI_VIDEO_URL,
} from '../consts';
import StoreAppleIcon from './icons/StoreAppleIcon.astro';
import StoreGooglePlayIcon from './icons/StoreGooglePlayIcon.astro';

const videoSrc = CITY_PULSE_UI_VIDEO_URL?.trim() || '';
const poster = CITY_PULSE_UI_SCREENSHOT;
const appHref = CITY_PULSE_APP_STORE_URL || null;
const playHref = CITY_PULSE_PLAY_STORE_URL || null;

const features = [
  {
    n: '01',
    title: 'REAL-TIME DISCOVERY',
    body: 'Low-latency data streams for urban navigation.',
  },
  {
    n: '02',
    title: 'CINEMATIC INTERFACE',
    body: 'Aerospace-grade UI precision.',
  },
  {
    n: '03',
    title: 'GEOSPATIAL INTELLIGENCE',
    body: 'Proprietary mapping engine.',
  },
];
---

<section
  id="city-pulse"
  data-city-pulse-showcase
  class="relative z-10 overflow-hidden border-b border-black/10 py-16 md:py-28"
  aria-labelledby="city-pulse-main-title"
>
  <div class="mx-auto w-full max-w-6xl px-6 md:px-12">
    <p class="text-xs uppercase tracking-[0.22em] text-black/45">Venture pipeline</p>

    <h2
      id="city-pulse-main-title"
      class="mt-3 text-3xl font-semibold tracking-tight text-[#0D0D0D] md:text-4xl"
    >
      Venture 01: Social Discovery
    </h2>

    <p class="mt-2 text-lg font-medium tracking-tight text-[#0D0D0D]/80 md:text-xl">
      City Pulse — in your hand
    </p>

    <p class="mt-5 max-w-3xl text-base leading-relaxed text-[#0D0D0D]/65 md:text-lg">
      Flagship product: urban discovery reimagined as a cinematic, data-aware mobile experience—built
      in-house end to end. Signal over noise; motion over middleware.
    </p>
    <p class="mt-4 max-w-3xl text-sm leading-relaxed text-[#0D0D0D]/55 md:text-base">
      Mission: make the city legible in real time—presence over performance metrics, craft over vendor
      theater.
    </p>
    <p class="mt-4 max-w-2xl text-sm text-[#0D0D0D]/50">
      A live look at the interface: discovery, motion, and map intelligence in one surface.
    </p>

    <div
      class="mt-14 grid grid-cols-1 items-start gap-12 lg:grid-cols-12 lg:gap-14 xl:gap-16"
    >
      <!-- Device (3D frame) — data-showcase-device for GSAP -->
      <div class="flex w-full justify-center lg:col-span-5 lg:justify-start">
        <div
          data-showcase-device
          class="venture-device-wrap flex justify-center [will-change:transform,opacity]"
        >
          <div class="venture-device-perspective">
            <div class="venture-iphone">
              <div class="venture-iphone-notch" aria-hidden="true"></div>
              <div class="venture-iphone-screen">
                {videoSrc ? (
                  <video
                    class="venture-iphone-video"
                    src={videoSrc}
                    poster={poster}
                    autoplay
                    muted
                    playsinline
                    loop
                  />
                ) : (
                  <img
                    src={poster}
                    alt="City Pulse app interface"
                    class="venture-iphone-fallback h-full w-full object-cover"
                    width="390"
                    height="844"
                    loading="lazy"
                  />
                )}
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Feature triad + single store row -->
      <div class="min-w-0 space-y-10 lg:col-span-7">
        <ul class="space-y-8">
          {
            features.map((f) => (
              <li
                data-showcase-triad-item
                class="group border-b border-black/10 pb-8 last:border-0 last:pb-0 [will-change:transform,opacity]"
              >
                <div class="flex gap-5">
                  <span class="text-xs font-semibold tracking-[0.35em] text-[#0D0D0D]/35 tabular-nums">
                    {f.n}
                  </span>
                  <div>
                    <h3 class="text-sm font-semibold tracking-[0.12em] text-[#0D0D0D]">{f.title}</h3>
                    <p class="mt-2 max-w-xl leading-relaxed text-[#1A1A1A]/70">{f.body}</p>
                  </div>
                </div>
              </li>
            ))
          }
        </ul>

        <div
          data-showcase-stores
          class="flex flex-wrap items-center gap-4 pt-2 [will-change:transform,opacity]"
        >
          {appHref ? (
            <a
              href={appHref}
              target="_blank"
              rel="noreferrer"
              class="store-badge store-badge-pill focus-visible:outline-none inline-flex h-[52px] min-w-[11rem] max-w-full items-stretch overflow-hidden rounded-xl bg-[#0D0D0D] text-white shadow-sm focus-visible:ring-2 focus-visible:ring-black/30 focus-visible:ring-offset-2"
              aria-label="Download on the App Store"
            >
              <span class="flex w-[52px] shrink-0 items-center justify-center border-r border-white/12 bg-[#0D0D0D]">
                <StoreAppleIcon class="h-8 w-8 text-white" />
              </span>
              <span class="flex min-w-0 flex-col justify-center px-4 py-1.5 text-left leading-tight">
                <span class="text-[9px] font-semibold uppercase tracking-[0.12em] text-white/75">
                  Download on the
                </span>
                <span class="text-[15px] font-bold tracking-tight text-white">App Store</span>
              </span>
            </a>
          ) : (
            <div
              class="store-badge store-badge-pill pointer-events-none inline-flex h-[52px] min-w-[11rem] max-w-full items-stretch overflow-hidden rounded-xl bg-[#0D0D0D] text-white opacity-45"
              title="App Store link coming soon"
            >
              <span class="flex w-[52px] shrink-0 items-center justify-center border-r border-white/12">
                <StoreAppleIcon class="h-8 w-8 text-white/90" />
              </span>
              <span class="flex min-w-0 flex-col justify-center px-4 py-1.5 text-left leading-tight">
                <span class="text-[9px] font-semibold uppercase tracking-[0.12em] text-white/75">
                  Download on the
                </span>
                <span class="text-[15px] font-bold tracking-tight text-white">App Store</span>
              </span>
            </div>
          )}

          {playHref ? (
            <a
              href={playHref}
              target="_blank"
              rel="noreferrer"
              class="store-badge store-badge-pill focus-visible:outline-none inline-flex h-[52px] min-w-[11rem] max-w-full items-stretch overflow-hidden rounded-xl bg-[#0D0D0D] text-white shadow-sm focus-visible:ring-2 focus-visible:ring-black/30 focus-visible:ring-offset-2"
              aria-label="Get it on Google Play"
            >
              <span class="flex w-[52px] shrink-0 items-center justify-center border-r border-white/12 bg-[#0D0D0D]">
                <StoreGooglePlayIcon class="h-8 w-8" colorful gradientId="gp-cp-active" />
              </span>
              <span class="flex min-w-0 flex-col justify-center px-4 py-1.5 text-left leading-tight">
                <span class="text-[9px] font-semibold uppercase tracking-[0.1em] text-white/75">Get it on</span>
                <span class="text-[15px] font-bold tracking-tight text-white">Google Play</span>
              </span>
            </a>
          ) : (
            <div
              class="store-badge store-badge-pill pointer-events-none inline-flex h-[52px] min-w-[11rem] max-w-full items-stretch overflow-hidden rounded-xl bg-[#0D0D0D] text-white opacity-45"
              title="Play Store link coming soon"
            >
              <span class="flex w-[52px] shrink-0 items-center justify-center border-r border-white/12">
                <StoreGooglePlayIcon class="h-8 w-8 opacity-95" colorful gradientId="gp-cp-soon" />
              </span>
              <span class="flex min-w-0 flex-col justify-center px-4 py-1.5 text-left leading-tight">
                <span class="text-[9px] font-semibold uppercase tracking-[0.1em] text-white/75">Get it on</span>
                <span class="text-[15px] font-bold tracking-tight text-white">Google Play</span>
              </span>
            </div>
          )}
        </div>
      </div>
    </div>
  </div>
</section>
