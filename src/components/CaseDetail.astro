---
import type { Case } from '../data/cases';
import { ArrowLeft } from 'lucide-astro';
import PrismScene from './PrismScene.astro';
import { PRESENCE_AUDIT_HREF } from '../consts';

const { case: caseData } = Astro.props as { case: Case };

if (!caseData) {
  throw new Error('CaseDetail requires a `case` prop.');
}
---

<section class="relative z-20 isolate pt-28 pb-24 overflow-hidden will-change-transform">
  <div class="mx-auto w-full max-w-6xl px-6 md:px-12">
    <a
      href="/"
      class="inline-flex items-center gap-2 text-[#0D0D0D]/70 hover:text-[#0D0D0D] transition-colors"
    >
      <ArrowLeft class="h-4 w-4" />
      <span class="text-sm">Back to home</span>
    </a>

    <div class="mt-10 grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
      <div class="lg:col-span-7">
        <div class="text-xs font-semibold tracking-[0.35em] text-[#0D0D0D]/40 uppercase">
          <span data-city-overlap="meta">{caseData.indexLabel}</span>
        </div>
        <h1
          data-reveal="chars"
          data-case-title
          data-city-overlap="title"
          class="mt-4 text-3xl md:text-5xl font-semibold tracking-tight text-[#0D0D0D]"
        >
          {caseData.title}
        </h1>

        <p data-reveal="lines" data-city-overlap="body" class="mt-5 text-[#0D0D0D]/60 leading-relaxed max-w-2xl">
          {caseData.summary}
        </p>

        <div class="mt-10">
          <a
            href={PRESENCE_AUDIT_HREF}
            class="presence-audit-btn inline-flex items-center gap-2 rounded-full border border-black/20 bg-transparent px-6 py-3 backdrop-blur-md hover:border-black/40 hover:bg-black/5 transition-colors"
          >
            <span class="text-sm tracking-wide font-medium">Request a Presence Audit</span>
          </a>
        </div>
      </div>

      <div class="lg:col-span-5">
        <div
          class="relative mb-6 rounded-2xl border border-black/10 bg-black/5 overflow-hidden aspect-[4/3]"
          data-case-hero={caseData.id}
        >
          <img src={caseData.hoverImage} alt="" class="w-full h-full object-cover" draggable="false" />
        </div>
        <div class="rounded-2xl border border-black/10 bg-black/5 backdrop-blur-md p-6 glass-surface prism-preview-card">
          <div class="text-xs font-semibold tracking-[0.3em] text-[#0D0D0D]/40 uppercase">
            Prism Preview
          </div>
          <div class="mt-6">
            <PrismScene />
          </div>
        </div>
      </div>
    </div>

    <div class="mt-16">
      <slot />
    </div>
  </div>
</section>

