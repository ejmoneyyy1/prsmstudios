---
import { Layers, Zap, Rocket } from 'lucide-astro';
import { coreServices } from '../services';

const iconMap = {
  layers: Layers,
  zap: Zap,
  rocket: Rocket,
} as const;
---

<section
  class="relative z-10 py-16 md:py-24 border-y border-black/10 bg-black/[0.02]"
  aria-labelledby="core-services-heading"
>
  <div class="mx-auto w-full max-w-6xl px-6 md:px-12">
    <p class="text-xs uppercase tracking-[0.22em] text-black/45">The consultation pivot</p>
    <h2
      id="core-services-heading"
      class="mt-3 text-2xl md:text-3xl font-semibold tracking-tight text-[#0D0D0D]"
    >
      Core services
    </h2>
    <p class="mt-3 text-sm md:text-base text-[#0D0D0D]/55 max-w-2xl">
      Positioning, product, and experience—how a venture studio ships, not how a résumé reads.
    </p>

    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {coreServices.map((s) => {
        const Icon = iconMap[s.icon];
        return (
          <article class="core-services-card rounded-2xl border border-black/10 bg-white/60 backdrop-blur-md p-6 md:p-8 glass-surface flex flex-col">
            <div class="flex items-center gap-3 text-[#0D0D0D]/50">
              <Icon class="h-5 w-5" strokeWidth={1.5} aria-hidden="true" />
            </div>
            <h3 class="mt-5 text-lg font-semibold tracking-tight text-[#0D0D0D]">{s.title}</h3>
            <p class="mt-3 text-sm text-[#0D0D0D]/65 leading-relaxed flex-1">{s.description}</p>
            <a
              href={s.inquiryHref}
              class="presence-audit-btn mt-6 inline-flex w-fit items-center gap-2 rounded-full border border-black/20 bg-white/50 px-4 py-2 text-xs font-semibold uppercase tracking-[0.12em] text-[#0D0D0D]/85 backdrop-blur-md transition-colors hover:border-black/40 hover:bg-white/80 core-services-cta"
            >
              {s.inquiryLabel}
            </a>
          </article>
        );
      })}
    </div>
  </div>
</section>
