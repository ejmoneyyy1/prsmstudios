---
/**
 * Brand velocity graph — upward signal line with scroll-driven draw + glow (“The Signal”).
 */
---

<section
  data-tech-stack
  style="transform: translateZ(0)"
  class="mt-16 rounded-3xl border border-black/10 bg-transparent backdrop-blur-md p-6 glass-surface"
>
  <div class="overflow-hidden">
    <p class="text-xs font-semibold tracking-[0.28em] uppercase text-[#0D0D0D]/45">The signal</p>
    <h3 data-reveal="chars" class="mt-2 text-lg font-semibold tracking-tight text-[#0D0D0D]">
      Brand velocity
    </h3>
  </div>

  <div class="mt-6 grid grid-cols-1 lg:grid-cols-12 gap-8 items-center">
    <div class="lg:col-span-8">
      <svg
        data-tech-stack-svg
        viewBox="0 0 920 200"
        class="w-full h-auto"
        role="img"
        aria-label="Upward brand velocity chart: authority to conversion"
      >
        <defs>
          <!-- Glow stack for “The Signal” -->
          <filter id="signal-glow" x="-40%" y="-40%" width="180%" height="180%" color-interpolation-filters="sRGB">
            <feGaussianBlur in="SourceGraphic" stdDeviation="4" result="blur1" />
            <feGaussianBlur in="SourceGraphic" stdDeviation="12" result="blur2" />
            <feMerge>
              <feMergeNode in="blur2" />
              <feMergeNode in="blur1" />
              <feMergeNode in="SourceGraphic" />
            </feMerge>
          </filter>
          <linearGradient id="signal-line-grad" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="#0d0d0d" stop-opacity="0.35" />
            <stop offset="45%" stop-color="#0d0d0d" stop-opacity="0.85" />
            <stop offset="100%" stop-color="#2563eb" stop-opacity="0.95" />
          </linearGradient>
        </defs>

        <!-- Baseline (subtle) -->
        <line x1="48" y1="168" x2="872" y2="168" stroke="rgba(0,0,0,0.08)" stroke-width="1" />

        <!-- Wide glow stroke (drawn under main line) -->
        <path
          data-velocity-glow
          d="M 56 158 C 180 158, 260 128, 380 108 S 620 62, 864 36"
          fill="none"
          stroke="url(#signal-line-grad)"
          stroke-width="10"
          stroke-linecap="round"
          stroke-linejoin="round"
          opacity="0.35"
          filter="url(#signal-glow)"
        />

        <!-- Primary chart line (scroll-drawn; stroke-dash “drawSVG” style) -->
        <path
          data-velocity-line
          d="M 56 158 C 180 158, 260 128, 380 108 S 620 62, 864 36"
          fill="none"
          stroke="url(#signal-line-grad)"
          stroke-width="2.25"
          stroke-linecap="round"
          stroke-linejoin="round"
        />

        <!-- End cap: signal pulse -->
        <circle cx="864" cy="36" r="5" fill="#2563eb" opacity="0.25" data-velocity-cap />
        <circle cx="864" cy="36" r="3" fill="#1d4ed8" data-velocity-cap-core />

        <g fill="rgba(26,26,26,0.55)" font-size="10" letter-spacing="0.18em" font-weight="600">
          <text x="56" y="192">BRAND AUTHORITY</text>
          <text x="864" y="192" text-anchor="end">CONVERSION VELOCITY</text>
        </g>
      </svg>
    </div>

    <div class="lg:col-span-4">
      <div class="space-y-6 text-xs tracking-[0.22em] uppercase text-[#0D0D0D]/50">
        <div class="overflow-hidden opacity-0" data-velocity-label-mask="authority">
          <span data-velocity-label="authority" class="inline-block font-semibold tracking-[0.2em] text-[#1A1A1A]/90">
            BRAND AUTHORITY
          </span>
        </div>
        <div class="overflow-hidden opacity-0" data-velocity-label-mask="conversion">
          <span data-velocity-label="conversion" class="inline-block font-semibold tracking-[0.2em] text-[#1A1A1A]/90">
            CONVERSION VELOCITY
          </span>
        </div>
      </div>

      <p data-reveal="lines" class="mt-6 text-[#0D0D0D]/60 leading-relaxed">
        Narrative clarity compounds into measurable lift—creative systems engineered to move the curve, not
        just the metrics deck.
      </p>
    </div>
  </div>
</section>
