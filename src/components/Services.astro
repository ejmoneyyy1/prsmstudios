---
import { ArrowRight } from 'lucide-astro';
import { missionCriticalServices } from '../services';
---

<section id="services" class="relative z-10 py-60">
  <div class="mx-auto w-full max-w-6xl px-6 md:px-12">
    <div class="max-w-3xl">
      <h2 data-reveal="chars" class="text-2xl md:text-3xl font-semibold tracking-tight text-[#0D0D0D]">
        Work
      </h2>
      <p class="mt-4 text-[#0D0D0D]/60 leading-relaxed">
        Engineering-led systems for rebranding, product clarity, cloud-grade performance, and venture-grade
        deployment.
      </p>
    </div>

    <div class="mt-20 space-y-16">
      {missionCriticalServices.map((item, index) => (
        <article
          data-reveal="chars"
          class={`max-w-3xl ${index === 1 ? 'ml-auto' : ''} ${index === 2 ? 'ml-6 md:ml-20' : ''}`}
        >
          <div class="text-xs tracking-[0.3em] text-[#0D0D0D]/40">{item.id}</div>
          <h3 class="mt-3 text-2xl md:text-4xl font-semibold tracking-tight text-[#0D0D0D]">{item.title}</h3>
          <p class="mt-4 text-[#0D0D0D]/60 leading-relaxed max-w-xl">{item.copy}</p>
          {item.features && (
            <p class="mt-3 text-sm font-medium tracking-wide text-[#0D0D0D]/50">{item.features}</p>
          )}
          <a
            href={item.ctaHref}
            class="mt-6 inline-flex items-center gap-2 text-[#0D0D0D]/75 hover:text-[#0D0D0D] transition-colors"
          >
            <span class="text-sm tracking-wide">{item.ctaLabel}</span>
            <ArrowRight class="h-4 w-4" aria-hidden="true" />
          </a>
        </article>
      ))}
    </div>
  </div>
</section>
