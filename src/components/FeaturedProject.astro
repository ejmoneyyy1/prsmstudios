---
/**
 * Venture 01 — asymmetric 60/40 split: mission + stores | 3D iPhone + City Pulse loop.
 */
import {
  CITY_PULSE_APP_STORE_URL,
  CITY_PULSE_PLAY_STORE_URL,
  CITY_PULSE_UI_SCREENSHOT,
  CITY_PULSE_UI_VIDEO_URL,
} from '../consts';
import StoreAppleIcon from './icons/StoreAppleIcon.astro';
import StoreGooglePlayIcon from './icons/StoreGooglePlayIcon.astro';

const appHref = CITY_PULSE_APP_STORE_URL || null;
const playHref = CITY_PULSE_PLAY_STORE_URL || null;
const videoSrc = CITY_PULSE_UI_VIDEO_URL?.trim() || '';
const poster = CITY_PULSE_UI_SCREENSHOT;
---

<section class="relative z-10 py-16 md:py-28" aria-labelledby="venture-01-heading">
  <div class="mx-auto w-full max-w-6xl px-6 md:px-12">
    <p class="text-xs uppercase tracking-[0.22em] text-black/45">Venture pipeline</p>

    <div
      class="venture-pipeline-grid mt-10 grid grid-cols-1 items-start gap-12 lg:grid-cols-[minmax(0,3fr)_minmax(0,2fr)] lg:gap-14 xl:gap-16"
    >
      <!-- Left 60%: text + mission + badges -->
      <div class="min-w-0 pr-0 lg:pr-4">
        <h2
          id="venture-01-heading"
          class="text-3xl font-semibold tracking-tight text-[#0D0D0D] md:text-4xl"
        >
          Venture 01: Social Discovery
        </h2>
        <p class="mt-5 text-base leading-relaxed text-[#0D0D0D]/65 md:text-lg">
          Flagship product: urban discovery reimagined as a cinematic, data-aware mobile experience—built
          in-house end to end. Signal over noise; motion over middleware.
        </p>
        <p class="mt-4 text-sm leading-relaxed text-[#0D0D0D]/55 md:text-base">
          Mission: make the city legible in real time—presence over performance metrics, craft over vendor
          theater.
        </p>

        <div class="mt-10 flex flex-wrap items-center gap-4">
          {appHref ? (
            <a
              href={appHref}
              target="_blank"
              rel="noreferrer"
              class="store-badge store-badge-pill focus-visible:ring-2 focus-visible:ring-black/30 focus-visible:ring-offset-2 focus-visible:outline-none inline-flex h-[52px] min-w-[11rem] max-w-full items-stretch overflow-hidden rounded-xl bg-[#0D0D0D] text-white shadow-sm"
              aria-label="Download on the App Store"
            >
              <span class="flex w-[52px] shrink-0 items-center justify-center border-r border-white/12 bg-[#0D0D0D]">
                <StoreAppleIcon class="h-8 w-8 text-white" />
              </span>
              <span class="flex min-w-0 flex-col justify-center px-4 py-1.5 text-left leading-tight">
                <span class="text-[9px] font-semibold uppercase tracking-[0.12em] text-white/75">Download on the</span>
                <span class="text-[15px] font-bold tracking-tight text-white">App Store</span>
              </span>
            </a>
          ) : (
            <div
              class="store-badge store-badge-pill pointer-events-none inline-flex h-[52px] min-w-[11rem] max-w-full items-stretch overflow-hidden rounded-xl bg-[#0D0D0D] text-white opacity-45"
              title="App Store link coming soon"
            >
              <span class="flex w-[52px] shrink-0 items-center justify-center border-r border-white/12">
                <StoreAppleIcon class="h-8 w-8 text-white/90" />
              </span>
              <span class="flex min-w-0 flex-col justify-center px-4 py-1.5 text-left leading-tight">
                <span class="text-[9px] font-semibold uppercase tracking-[0.12em] text-white/75">Download on the</span>
                <span class="text-[15px] font-bold tracking-tight text-white">App Store</span>
              </span>
            </div>
          )}

          {playHref ? (
            <a
              href={playHref}
              target="_blank"
              rel="noreferrer"
              class="store-badge store-badge-pill focus-visible:ring-2 focus-visible:ring-black/30 focus-visible:ring-offset-2 focus-visible:outline-none inline-flex h-[52px] min-w-[11rem] max-w-full items-stretch overflow-hidden rounded-xl bg-[#0D0D0D] text-white shadow-sm"
              aria-label="Get it on Google Play"
            >
              <span class="flex w-[52px] shrink-0 items-center justify-center border-r border-white/12 bg-[#0D0D0D]">
                <StoreGooglePlayIcon class="h-8 w-8" colorful gradientId="gp-feat-active" />
              </span>
              <span class="flex min-w-0 flex-col justify-center px-4 py-1.5 text-left leading-tight">
                <span class="text-[9px] font-semibold uppercase tracking-[0.1em] text-white/75">Get it on</span>
                <span class="text-[15px] font-bold tracking-tight text-white">Google Play</span>
              </span>
            </a>
          ) : (
            <div
              class="store-badge store-badge-pill pointer-events-none inline-flex h-[52px] min-w-[11rem] max-w-full items-stretch overflow-hidden rounded-xl bg-[#0D0D0D] text-white opacity-45"
              title="Play Store link coming soon"
            >
              <span class="flex w-[52px] shrink-0 items-center justify-center border-r border-white/12">
                <StoreGooglePlayIcon class="h-8 w-8 opacity-95" colorful gradientId="gp-feat-soon" />
              </span>
              <span class="flex min-w-0 flex-col justify-center px-4 py-1.5 text-left leading-tight">
                <span class="text-[9px] font-semibold uppercase tracking-[0.1em] text-white/75">Get it on</span>
                <span class="text-[15px] font-bold tracking-tight text-white">Google Play</span>
              </span>
            </div>
          )}
        </div>
      </div>

      <!-- Right 40%: 3D iPhone + UI loop -->
      <div class="venture-device-wrap flex w-full justify-center lg:justify-end lg:pl-2">
        <div class="venture-device-perspective">
          <div class="venture-iphone">
            <div class="venture-iphone-notch" aria-hidden="true" />
            <div class="venture-iphone-screen">
              {videoSrc ? (
                <video
                  class="venture-iphone-video"
                  src={videoSrc}
                  poster={poster}
                  autoplay
                  muted
                  playsinline
                  loop
                />
              ) : (
                <img
                  src={poster}
                  alt=""
                  class="venture-iphone-fallback h-full w-full object-cover"
                  width="390"
                  height="844"
                  loading="lazy"
                />
              )}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
