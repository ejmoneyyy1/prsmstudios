---
import { cases } from '../data/cases';
---

<section id="cases" class="relative z-20 py-20 overflow-hidden">
  <div class="mx-auto w-full max-w-6xl px-6 md:px-12">
    <div class="max-w-3xl">
      <div class="overflow-hidden">
        <h2
          data-reveal="chars"
          class="text-2xl md:text-3xl font-semibold tracking-tight text-[#0D0D0D]"
        >
          Grid List
        </h2>
      </div>
      <p data-reveal="lines" class="mt-4 text-[#0D0D0D]/60 leading-relaxed">
        Minimal titles. Maximum presence. Hover to reveal the work.
      </p>
    </div>

    <div class="mt-14">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-10 gap-y-8">
        {cases.map((c) =>
          c.id === 'venture-consultation' ? (
            <article
              class="group relative block"
              data-case-item
              data-case-id={c.id}
              data-case-hover-img={c.hoverImage}
            >
              {/* Full-card target to /audit; City Pulse is an exception (pointer-events) */}
              <a
                href={c.route}
                class="absolute inset-0 z-[1] rounded-sm outline-offset-4 focus-visible:outline focus-visible:outline-2 focus-visible:outline-[#0D0D0D]/25"
                aria-label={`${c.indexLabel} ${c.title}. ${c.actionLabel}`}
              >
                <span class="sr-only">{c.actionLabel}</span>
              </a>

              <div class="relative z-[2] pointer-events-none">
                <div class="flex flex-wrap items-baseline justify-between gap-x-6 gap-y-2">
                  <div class="flex min-w-0 flex-wrap items-baseline gap-x-6 gap-y-1">
                    <div class="text-xs tracking-[0.35em] text-[#0D0D0D]/40 uppercase">
                      {c.indexLabel}
                    </div>
                    <div class="text-2xl md:text-4xl font-semibold tracking-tight text-[#0D0D0D]">
                      {c.title}
                    </div>
                  </div>

                  <div
                    data-case-view
                    class="shrink-0 max-w-[11rem] text-right text-[10px] leading-snug tracking-[0.2em] text-[#0D0D0D]/30 uppercase transition-all duration-300 group-hover:opacity-100 opacity-70 group-hover:translate-x-1 sm:max-w-none sm:text-xs sm:tracking-[0.3em]"
                  >
                    <span class="sm:hidden">{c.actionLabelShort}</span>
                    <span class="hidden sm:inline">{c.actionLabel}</span>
                  </div>
                </div>

                <p class="mt-3 max-w-xl text-sm text-[#0D0D0D]/55 leading-relaxed">
                  Have a high-stakes idea? We don&apos;t just consult; we build. See{' '}
                  <a
                    href="/city-pulse"
                    class="pointer-events-auto relative z-[3] font-medium text-[#0D0D0D]/75 underline decoration-black/15 underline-offset-4 transition-colors hover:text-[#0D0D0D] hover:decoration-black/35"
                  >
                    City Pulse
                  </a>{' '}
                  for our internal engineering benchmark.
                </p>

                <div class="mt-4 relative w-40 md:w-48 aspect-[4/3] overflow-hidden rounded-xl border border-black/10 bg-black/5">
                  <img
                    src={c.hoverImage}
                    alt=""
                    class="w-full h-full object-cover"
                    draggable="false"
                    data-case-thumb={c.id}
                  />
                </div>

                <div class="mt-6 h-px w-full bg-black/10" />
              </div>
            </article>
          ) : (
            <a
              href={c.route}
              class="group block"
              data-case-item
              data-case-id={c.id}
              data-case-hover-img={c.hoverImage}
              aria-label={`${c.indexLabel} ${c.title}`}
            >
              <div class="flex flex-wrap items-baseline justify-between gap-x-6 gap-y-2">
                <div class="flex min-w-0 flex-wrap items-baseline gap-x-6 gap-y-1">
                  <div class="text-xs tracking-[0.35em] text-[#0D0D0D]/40 uppercase">
                    {c.indexLabel}
                  </div>
                  <div class="text-2xl md:text-4xl font-semibold tracking-tight text-[#0D0D0D]">
                    {c.title}
                  </div>
                </div>

                <div
                  data-case-view
                  class="shrink-0 text-xs tracking-[0.3em] text-[#0D0D0D]/30 uppercase transition-all duration-300 group-hover:opacity-100 opacity-70 group-hover:translate-x-1"
                >
                  View
                </div>
              </div>

              <div class="mt-4 relative w-40 md:w-48 aspect-[4/3] overflow-hidden rounded-xl border border-black/10 bg-black/5">
                <img
                  src={c.hoverImage}
                  alt=""
                  class="w-full h-full object-cover"
                  draggable="false"
                  data-case-thumb={c.id}
                />
              </div>

              <div class="mt-6 h-px w-full bg-black/10" />
            </a>
          )
        )}
      </div>
    </div>
  </div>

  <!-- Global hover reveal layer -->
  <div
    data-case-hover-outer
    class="fixed top-0 left-0 z-[100] pointer-events-none opacity-0"
    aria-hidden="true"
  >
    <div class="absolute left-0 top-0 -translate-x-1/2 -translate-y-1/2 w-[min(56vw,560px)] aspect-[4/3]">
      <img
        data-case-hover-img-el
        class="w-full h-full object-cover rounded-2xl border border-black/10 bg-black/5 backdrop-blur-md"
        src=""
        alt=""
        draggable="false"
      />
    </div>
  </div>
</section>
