---
import { Cloud, GraduationCap, ShieldCheck } from 'lucide-astro';
import PrismScene from './PrismScene.astro';

const subhead =
  'We take businesses from zero to one, or evolve existing brands into high-performance digital assets.';
---

<section class="relative z-10 flex flex-col justify-center overflow-hidden py-28 will-change-transform safari-depth-lock" data-hero-section>
  <!-- Refraction effect layers -->
  <div class="absolute inset-0 pointer-events-none">
    <div data-prsm-beam-in class="absolute left-0 top-1/2 h-px bg-white/80 w-0"></div>
    <div data-prsm-fan="c" class="absolute left-1/2 top-1/2 h-px w-0 bg-cyan-300/50 blur-[1px]"></div>
    <div data-prsm-fan="m" class="absolute left-1/2 top-1/2 h-px w-0 bg-fuchsia-300/45 blur-[1px]"></div>
    <div data-prsm-fan="g" class="absolute left-1/2 top-1/2 h-px w-0 bg-yellow-200/45 blur-[1px]"></div>
    <div data-prsm-fan="w" class="absolute left-1/2 top-1/2 h-px w-0 bg-white/35 blur-[1px]"></div>
  </div>

  <div class="mx-auto w-full max-w-6xl px-6 md:px-12">
    <div class="relative max-w-5xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
        <div class="lg:col-span-7">
          <p class="text-xs uppercase tracking-[0.22em] text-white/45">ABOUT</p>
          <h1
            data-reveal="chars"
            class="mt-4 text-4xl md:text-6xl font-black tracking-tighter leading-[1.02] text-[#F5F5F7]"
          >
            Digital Growth, Refracted.
          </h1>
          <h2 class="mt-4 text-sm md:text-base font-black tracking-[0.2em] uppercase text-[#F5F5F7]">
            PRSM STUDIO.
          </h2>

          <p data-reveal="lines" class="mt-8 text-base md:text-lg text-[#F5F5F7]/60 leading-relaxed max-w-3xl">
            {subhead}
          </p>

          <div
            class="mt-12 w-fit bg-white/5 backdrop-blur-2xl border border-white/10 rounded-full px-10 py-4 text-[10px] tracking-[0.4em] text-[#F5F5F7]/75 text-center uppercase trust-bar-card"
          >
            <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2">
              <div class="flex items-center gap-2">
                <Cloud class="h-4 w-4 text-[#F5F5F7]/75" strokeWidth={1.5} />
                <span>AWS SOLUTIONS ARCHITECT</span>
              </div>
              <div class="flex items-center gap-2">
                <GraduationCap class="h-4 w-4 text-[#F5F5F7]/75" strokeWidth={1.5} />
                <span>PRSM ENGINEERED</span>
              </div>
              <div class="flex items-center gap-2">
                <ShieldCheck class="h-4 w-4 text-[#F5F5F7]/75" strokeWidth={1.5} />
                <span>CLOUD-NATIVE SCALABILITY</span>
              </div>
            </div>
          </div>
        </div>

        <div class="lg:col-span-5">
          <div class="w-full rounded-3xl border border-white/10 bg-white/5 backdrop-blur-md p-6 glass-surface prism-preview-card">
            <div class="text-xs font-semibold tracking-[0.3em] text-[#F5F5F7]/40 uppercase">
              Prism Preview
            </div>
            <div class="mt-6">
              <PrismScene />
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

