---
import { ArrowRight } from 'lucide-astro';

const items = [
  {
    id: '01',
    title: 'Brand Reframing',
    copy: 'Identity systems, narrative positioning, and precision design for high-trust digital presence.',
  },
  {
    id: '02',
    title: 'Experience Engineering',
    copy: 'Conversion-focused UI architecture, motion systems, and performant front-end implementation.',
  },
  {
    id: '03',
    title: 'Cloud-Native Scale',
    copy: 'AWS-backed infrastructure strategy for reliability, velocity, and long-term growth.',
  },
];
---

<section id="services" class="relative z-10 py-60">
  <div class="mx-auto w-full max-w-6xl px-6 md:px-12">
    <div class="max-w-3xl">
      <h2 data-reveal="chars" class="text-2xl md:text-3xl font-semibold tracking-tight text-[#F5F5F7]">
        Work
      </h2>
      <p class="mt-4 text-[#F5F5F7]/60 leading-relaxed">
        Engineering-led systems for rebranding, product clarity, and cloud-grade performance.
      </p>
    </div>

    <div class="mt-20 space-y-16">
      {items.map((item, index) => (
        <article
          data-reveal="chars"
          class={`max-w-3xl ${index === 1 ? 'ml-auto' : ''} ${index === 2 ? 'ml-6 md:ml-20' : ''}`}
        >
          <div class="text-xs tracking-[0.3em] text-[#F5F5F7]/40">{item.id}</div>
          <h3 class="mt-3 text-2xl md:text-4xl font-semibold tracking-tight text-[#F5F5F7]">{item.title}</h3>
          <p class="mt-4 text-[#F5F5F7]/60 leading-relaxed max-w-xl">{item.copy}</p>
          <a
            href="#city-pulse"
            class="mt-6 inline-flex items-center gap-2 text-[#F5F5F7]/75 hover:text-[#F5F5F7] transition-colors"
          >
            <span class="text-sm tracking-wide">Learn more</span>
            <ArrowRight class="h-4 w-4" />
          </a>
        </article>
      ))}
    </div>
  </div>
</section>

