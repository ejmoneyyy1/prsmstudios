<div data-prism-bg class="fixed inset-0 z-[1] pointer-events-none">
  <canvas data-prism-canvas class="w-full h-full block"></canvas>
</div>

<script type="text/plain" data-prsm-inline-disabled="true">
  import * as THREE from 'three';
  import gsap from 'gsap';
  import { EffectComposer } from 'three/examples/jsm/postprocessing/EffectComposer.js';
  import { RenderPass } from 'three/examples/jsm/postprocessing/RenderPass.js';
  import { ShaderPass } from 'three/examples/jsm/postprocessing/ShaderPass.js';
  import { RGBShiftShader } from 'three/examples/jsm/shaders/RGBShiftShader.js';

  const mount = document.querySelector('[data-prism-bg]');
  const canvas = mount?.querySelector('[data-prism-canvas]');
  if (!mount || !canvas) {
    throw new Error('Fixed prism background mount missing.');
  }

  const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
  renderer.setSize(window.innerWidth, window.innerHeight);
  renderer.outputColorSpace = THREE.SRGBColorSpace;

  const scene = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(35, window.innerWidth / window.innerHeight, 0.1, 100);
  camera.position.set(0, 0, 6.5);

  const composer = new EffectComposer(renderer);
  composer.addPass(new RenderPass(scene, camera));
  const rgbPass = new ShaderPass(RGBShiftShader);
  rgbPass.uniforms.amount.value = 0.0008;
  composer.addPass(rgbPass);

  const prismGeo = new THREE.CylinderGeometry(1.05, 1.05, 2.4, 3, 1, false);
  prismGeo.rotateY(Math.PI / 2);
  const prismMat = new THREE.MeshPhysicalMaterial({
    color: new THREE.Color('#ffffff'),
    transmission: 1,
    thickness: 2,
    roughness: 0,
    metalness: 0,
    ior: 1.4,
    clearcoat: 1,
    clearcoatRoughness: 0,
    opacity: 0.95,
    transparent: true,
  });
  const prism = new THREE.Mesh(prismGeo, prismMat);
  prism.position.set(0, 0.2, 0);
  scene.add(prism);

  const keyLight = new THREE.DirectionalLight('#ffffff', 2.8);
  keyLight.position.set(2.2, 3, 5);
  scene.add(keyLight);

  const back = new THREE.PointLight('#ffffff', 2.2, 20);
  back.position.set(0, 0.2, -4);
  scene.add(back);

  const cyan = new THREE.Mesh(
    new THREE.PlaneGeometry(8.4, 3.2),
    new THREE.MeshBasicMaterial({ color: '#22d3ee', transparent: true, opacity: 0.1 })
  );
  cyan.position.set(-1, 0.05, -3);
  scene.add(cyan);

  const magenta = new THREE.Mesh(
    new THREE.PlaneGeometry(8.1, 3),
    new THREE.MeshBasicMaterial({ color: '#d946ef', transparent: true, opacity: 0.08 })
  );
  magenta.position.set(0.75, 0.1, -3.2);
  scene.add(magenta);

  const gold = new THREE.Mesh(
    new THREE.PlaneGeometry(8.3, 2.9),
    new THREE.MeshBasicMaterial({ color: '#facc15', transparent: true, opacity: 0.07 })
  );
  gold.position.set(1.2, -0.1, -3.4);
  scene.add(gold);

  const pointer = { x: 0, y: 0 };
  const setX = gsap.quickSetter(pointer, 'x');
  const setY = gsap.quickSetter(pointer, 'y');
  let speed = 0;
  let px = 0;
  let py = 0;
  let scrollTargetIntensity = 0;
  let scrollIntensity = 0;

  const onScrollIntensity = (e) => {
    const ce = e;
    const val = ce?.detail?.intensity ?? 0;
    scrollTargetIntensity = Math.max(0, Math.min(1, val));
  };

  window.addEventListener('prsm:scroll-intensity', onScrollIntensity);

  const onMove = (e) => {
    const nx = (e.clientX / window.innerWidth) * 2 - 1;
    const ny = (e.clientY / window.innerHeight) * 2 - 1;
    speed = Math.min(1, Math.hypot(nx - px, ny - py) * 2.8);
    px = nx;
    py = ny;
    setX(nx);
    setY(ny);
  };
  window.addEventListener('mousemove', onMove, { passive: true });

  const targetRot = { x: -0.08, y: 0 };
  const clock = new THREE.Clock();
  let running = true;
  const io = new IntersectionObserver(
    ([entry]) => {
      running = entry.isIntersecting;
    },
    { threshold: 0.01 }
  );
  io.observe(document.body);

  let signaled = false;
  const render = () => {
    if (running) {
      const t = clock.getElapsedTime();
      targetRot.x = -0.08 - pointer.y * 0.24;
      targetRot.y = pointer.x * 0.38;
      scrollIntensity += (scrollTargetIntensity - scrollIntensity) * 0.06;

      prism.rotation.x += (targetRot.x - prism.rotation.x) * 0.06;
      prism.rotation.y += (targetRot.y - prism.rotation.y) * 0.06;
      prism.rotation.z = Math.sin(t * 0.36) * 0.045 + scrollIntensity * 0.07;

      cyan.rotation.z = prism.rotation.y * 0.28;
      magenta.rotation.z = prism.rotation.y * 0.2;
      gold.rotation.z = prism.rotation.y * 0.12;

      rgbPass.uniforms.amount.value +=
        ((0.0008 + speed * 0.005 + scrollIntensity * 0.012) - rgbPass.uniforms.amount.value) * 0.08;
      speed *= 0.9;
      composer.render();

      if (!signaled) {
        signaled = true;
        window.dispatchEvent(new CustomEvent('prsm:prism-ready'));
      }
    }
    requestAnimationFrame(render);
  };
  requestAnimationFrame(render);

  const onResize = () => {
    const w = window.innerWidth;
    const h = window.innerHeight;
    renderer.setSize(w, h);
    composer.setSize(w, h);
    camera.aspect = w / h;
    camera.updateProjectionMatrix();
    window.dispatchEvent(new CustomEvent('prsm:prism-ready'));
  };
  window.addEventListener('resize', onResize, { passive: true });

  window.addEventListener(
    'beforeunload',
    () => {
      window.removeEventListener('mousemove', onMove);
      window.removeEventListener('resize', onResize);
      window.removeEventListener('prsm:scroll-intensity', onScrollIntensity);
      io.disconnect();
      prismGeo.dispose();
      prismMat.dispose();
      renderer.dispose();
    },
    { once: true }
  );
</script>

<script type="module" src="/src/scripts/prismBackground.ts"></script>

