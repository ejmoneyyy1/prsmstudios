<section data-tech-stack class="mt-16 rounded-3xl border border-white/10 bg-white/5 backdrop-blur-md p-6 glass-surface">
  <div class="overflow-hidden">
    <h3 data-reveal="chars" class="text-lg font-semibold tracking-tight text-[#F5F5F7]">
      Technical Stack
    </h3>
  </div>

  <div class="mt-6 grid grid-cols-1 lg:grid-cols-12 gap-8 items-center">
    <div class="lg:col-span-8">
      <svg
        data-tech-stack-svg
        viewBox="0 0 900 260"
        class="w-full h-auto"
        role="img"
        aria-label="Client to API Gateway to Lambda to DynamoDB serverless architecture flow"
      >
        <defs>
          <filter id="nodeGlow" x="-120%" y="-120%" width="340%" height="340%">
            <feGaussianBlur stdDeviation="5" result="blur" />
            <feMerge>
              <feMergeNode in="blur" />
              <feMergeNode in="SourceGraphic" />
            </feMerge>
          </filter>
        </defs>

        <g data-stack-path-group stroke="rgba(255,255,255,0.2)" stroke-width="1" fill="none">
          <path data-stack-path data-to="apigateway" d="M140 130 L310 130" />
          <path data-stack-path data-to="lambda" d="M410 130 L560 130" />
          <path data-stack-path data-to="dynamodb" d="M640 130 L780 130" />
        </g>

        <g>
          <circle data-stack-node="client" cx="110" cy="130" r="28" fill="none" stroke="rgba(255,255,255,0.85)" stroke-width="1" />
          <circle data-stack-glow="client" cx="110" cy="130" r="28" fill="none" stroke="white" stroke-width="1" opacity="0" filter="url(#nodeGlow)" />

          <rect data-stack-node="apigateway" x="310" y="102" width="100" height="56" rx="8" fill="none" stroke="rgba(255,255,255,0.85)" stroke-width="1" />
          <rect data-stack-glow="apigateway" x="310" y="102" width="100" height="56" rx="8" fill="none" stroke="white" stroke-width="1" opacity="0" filter="url(#nodeGlow)" />

          <rect data-stack-node="lambda" x="560" y="102" width="80" height="56" rx="8" fill="none" stroke="rgba(255,255,255,0.85)" stroke-width="1" />
          <rect data-stack-glow="lambda" x="560" y="102" width="80" height="56" rx="8" fill="none" stroke="white" stroke-width="1" opacity="0" filter="url(#nodeGlow)" />

          <rect data-stack-node="dynamodb" x="780" y="98" width="90" height="64" rx="8" fill="none" stroke="rgba(255,255,255,0.85)" stroke-width="1" />
          <rect data-stack-glow="dynamodb" x="780" y="98" width="90" height="64" rx="8" fill="none" stroke="white" stroke-width="1" opacity="0" filter="url(#nodeGlow)" />
        </g>

        <g fill="rgba(255,255,255,0.9)" font-size="12" letter-spacing="0.18em">
          <text x="83" y="185">CLIENT</text>
          <text x="312" y="185">API GATEWAY</text>
          <text x="566" y="185">LAMBDA</text>
          <text x="787" y="185">DYNAMODB</text>
        </g>

        <circle data-stack-ping cx="140" cy="130" r="4" fill="white" opacity="0" />
      </svg>
    </div>

    <div class="lg:col-span-4">
      <div class="space-y-4 text-xs tracking-[0.26em] uppercase text-[#F5F5F7]/45">
        <div class="overflow-hidden">
          <div data-stack-label="client" class="translate-y-full">AWS</div>
        </div>
        <div class="overflow-hidden">
          <div data-stack-label="apigateway" class="translate-y-full">AWS</div>
        </div>
        <div class="overflow-hidden">
          <div data-stack-label="lambda" class="translate-y-full">AWS</div>
        </div>
        <div class="overflow-hidden">
          <div data-stack-label="dynamodb" class="translate-y-full">AWS</div>
        </div>
      </div>

      <p data-reveal="lines" class="mt-6 text-[#F5F5F7]/60 leading-relaxed">
        Serverless scalability with AWS API Gateway, Lambda, and DynamoDB keeps CityPulse resilient
        under traffic spikes while preserving low latency and efficient cloud cost.
      </p>
    </div>
  </div>
</section>
